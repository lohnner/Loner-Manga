rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if true;
      allow create: if owner(uid) && request.resource.data.uid == uid;
      allow update: if owner(uid)
        && request.resource.data.uid == uid
        && resource.data.uid == uid
        && request.resource.data.watchedEpisodes is int
        && request.resource.data.watchedEpisodes >= 0
        && request.resource.data.watchedEpisodes <= 220
        && request.resource.data.myHeroWatchedEpisodes is int
        && request.resource.data.myHeroWatchedEpisodes >= 0
        && request.resource.data.myHeroWatchedEpisodes <= 170
        && request.resource.data.xp == (request.resource.data.watchedEpisodes + request.resource.data.myHeroWatchedEpisodes) * 22;
      allow delete: if false;
    }
  }
}
