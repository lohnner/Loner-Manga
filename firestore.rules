rules_version = '2';
service cloud.firestore { match /databases/{database}/documents {
  function signedIn(){ return request.auth != null; }
  function owner(uid){ return signedIn() && request.auth.uid == uid; }
  match /users/{uid} {
    allow read: if true;
    allow create: if owner(uid) && request.resource.data.uid == uid;
    allow update: if owner(uid) && request.resource.data.uid == uid && resource.data.uid == uid;
    allow delete: if false;
    match /comics/{comicId} { allow read: if true; allow create,update: if owner(uid) && request.resource.data.uid == uid; allow delete: if owner(uid); }
  }
  match /comics/{comicId}/interactions/{uid} { allow read: if true; allow create,update: if owner(uid) && request.resource.data.uid == uid; allow delete: if owner(uid); }
  // Documentos públicos contêm somente dados de vitrine/ranking. Toda escrita do
  // jogo é feita pelas Cloud Functions com Admin SDK.
  match /shops/{uid} { allow read: if true; allow write: if false;
    match /inventory/{id} { allow read: if owner(uid); allow write: if false; }
    match /boxes/{id} { allow read: if owner(uid); allow write: if false; }
    match /npcItems/{id} { allow read: if owner(uid); allow write: if false; }
    match /collectionVolumes/{id} { allow read: if owner(uid); allow write: if false; }
  }
  match /marketListings/{id} { allow read: if true; allow write: if false; }
} }
