rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }
    function validAnimeProfile(uid) {
      return request.resource.data.uid == uid
        && request.resource.data.animeProgress is map
        && request.resource.data.xp is int
        && request.resource.data.xp >= 0
        && request.resource.data.level is int
        && request.resource.data.level >= 1;
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if owner(uid) && validAnimeProfile(uid);
      allow update: if owner(uid)
        && resource.data.uid == uid
        && validAnimeProfile(uid);
      allow delete: if false;
    }
  }
}
